{
  "name": "nonebot-registry",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:preview": "vue-tsc && vite build --mode preview",
    "preview": "vite preview",
    "stylelint": "stylelint",
    "stylelint:fix": "npm run stylelint --fix",
    "lint": "npm run lint:js && npm run lint:style",
    "lint:fix": "npm run lint:js:fix && npm run lint:style:fix",
    "lint:js": "eslint \"**/*.{js,jsx,ts,tsx,cjs,mjs,vue}\"",
    "lint:js:fix": "eslint --fix \"**/*.{js,jsx,ts,tsx,cjs,mjs,vue}\"",
    "lint:style": "npm run stylelint \"**/*.{css,scss}\"",
    "lint:style:fix": "npm run stylelint:fix \"**/*.{css,scss}\"",
    "prepare": "node .husky/install.mjs"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@sentry/vue": "^10.46.0",
    "@vueuse/core": "^14.2.1",
    "ansi_up": "^6.0.6",
    "gsap": "^3.14.2",
    "highlight.js": "^11.11.1",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sentry/vite-plugin": "^5.1.1",
    "@types/node": "^25.5.0",
    "@unocss/eslint-config": "^66.6.7",
    "@unocss/transformer-directives": "^66.6.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.57.2",
    "unocss": "^66.6.7",
    "vite": "^8.0.3",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "esbuild",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
